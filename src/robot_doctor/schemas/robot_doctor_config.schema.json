{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robot-doctor.local/schemas/robot_doctor_config.schema.json",
  "title": "Robot Doctor Configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "max_file_size_bytes": {"type": "integer", "minimum": 1, "default": 5242880},
    "max_total_size_bytes": {"type": "integer", "minimum": 1, "default": 268435456},
    "max_files": {"type": "integer", "minimum": 1, "default": 100000},
    "max_repository_entries": {"type": "integer", "minimum": 1, "default": 250000},
    "dependency_mode": {"enum": ["off", "direct", "all"], "default": "direct"},
    "suppress_diagnostics": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^RD[0-9]{3}$"}},
    "severity_overrides": {"type": "object", "additionalProperties": {"enum": ["error", "warning", "info"]}},
    "ignore_dependencies": {"type": "array", "items": {"type": "string"}},
    "ignore_dependency_pairs": {"type": "array", "items": {"type": "string"}},
    "minimum_diagnostic_confidence": {"type": "number", "minimum": 0, "maximum": 1, "default": 0.0}
  }
}
