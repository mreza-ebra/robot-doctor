<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="probe_control" params="system_name joint_name plugin_name command:=effort">
    <ros2_control name="WrongSystem" type="system">
      <hardware>
        <plugin>probe_cpp/WrongHardware</plugin>
      </hardware>
      <joint name="wrong_joint">
        <command_interface name="effort"/>
      </joint>
    </ros2_control>
  </xacro:macro>
</robot>
